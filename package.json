{
  "name": "rf-social-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "node --env-file=.env.local server.js",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:node && npm run test:unit",
    "test:node": "node --test tests/validation.test.js tests/server.test.js",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:validation": "node --test tests/validation.test.js",
    "test:server": "node --test tests/server.test.js"
  },
  "dependencies": {
    "@clerk/react": "^6.0.1",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "inngest": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  }
