VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_JWT_KEY=replace_with_clerk_jwt_public_key
# Optional strict issuer check, e.g. https://your-clerk-domain.clerk.accounts.dev
CLERK_ISSUER=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-vercel-app.vercel.app
SESSION_SECRET=replace_with_a_long_random_secret

# Facebook Login + Instagram Graph API
# 1. Create a Meta app at developers.facebook.com/apps
# 2. Add products: Facebook Login, Instagram Graph API
# 3. Facebook Login → Settings → Valid OAuth Redirect URIs → add the FB_REDIRECT_URI below
# 4. Settings → Basic → copy App ID and App Secret
# 5. For dev: add Facebook test users so they can connect without App Review
# 6. For prod: submit for App Review with permissions:
#    instagram_basic, instagram_content_publish, pages_show_list,
#    pages_read_engagement, business_management
FB_APP_ID=replace_with_meta_app_id
FB_APP_SECRET=replace_with_meta_app_secret
FB_REDIRECT_URI=https://your-vercel-app.vercel.app/instagram/oauth/callback

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

ANTHROPIC_API_KEY=replace_with_server_side_ai_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional when a real publishing backend is ready.
VITE_PUBLISH_API_URL=
