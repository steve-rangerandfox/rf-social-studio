VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_JWT_KEY=replace_with_clerk_jwt_public_key
# Optional strict issuer check, e.g. https://your-clerk-domain.clerk.accounts.dev
CLERK_ISSUER=

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,https://your-vercel-app.vercel.app
SESSION_SECRET=replace_with_a_long_random_secret

# Instagram API with Instagram Login
# 1. Create a Meta app at developers.facebook.com/apps
# 2. Add product: "Instagram API with Instagram Login"  (NOT "Facebook Login")
# 3. Under that product → Settings → Valid OAuth Redirect URIs → add the FB_REDIRECT_URI below
# 4. Under that product → App ID and App Secret (these are product-level credentials)
# 5. For dev: add Instagram Test Users in App Dashboard → Roles → Test Users
# 6. For prod: submit for App Review with permissions:
#    instagram_business_basic, instagram_business_content_publish
FB_APP_ID=replace_with_instagram_app_id
FB_APP_SECRET=replace_with_instagram_app_secret
FB_REDIRECT_URI=https://your-vercel-app.vercel.app/instagram/oauth/callback

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

ANTHROPIC_API_KEY=replace_with_server_side_ai_key
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LinkedIn publishing
# 1. Create an app at linkedin.com/developers/apps (request "Share on LinkedIn"
#    and "Sign In with LinkedIn using OpenID Connect" products)
# 2. Auth → copy Client ID + Client Secret
# 3. Under OAuth 2.0 → Authorized redirect URLs, add LINKEDIN_REDIRECT_URI
LINKEDIN_CLIENT_ID=replace_with_linkedin_client_id
LINKEDIN_CLIENT_SECRET=replace_with_linkedin_client_secret
LINKEDIN_REDIRECT_URI=https://your-vercel-app.vercel.app/linkedin/oauth/callback

# Upstash Redis — cross-instance rate limiting (required in production)
# Create a database at upstash.com → copy REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_rest_token

# Inngest — scheduled publishing background worker
# 1. Create an account at inngest.com → create an app named "rf-social-studio"
# 2. In your Inngest app, copy the Event Key and Signing Key
# 3. In Vercel, add INNGEST_EVENT_KEY and INNGEST_SIGNING_KEY
# 4. After deploying, register the webhook: inngest.com → your app → Sync → add https://your-vercel-app.vercel.app/api/inngest
INNGEST_EVENT_KEY=replace_with_inngest_event_key
INNGEST_SIGNING_KEY=replace_with_inngest_signing_key

# Optional when a real publishing backend is ready.
VITE_PUBLISH_API_URL=
